rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tracks: anyone can read, no client writes
    match /tracks/{trackId} {
      allow read: if true;
      allow write: if false;
    }

    // Playlists: master playlist (ownerId == null) readable by all,
    // user playlists readable/writable only by their owner
    match /playlists/{playlistId} {
      allow read: if resource.data.ownerId == null
                  || (request.auth != null && resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerId == request.auth.uid;
    }

    // User profiles: users can only read/write their own profile
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Radio state: anyone can read, only server (admin SDK) writes
    match /radioState/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Track insights cache: anyone can read/write
    match /trackInsights/{trackId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
