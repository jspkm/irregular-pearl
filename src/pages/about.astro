---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { seedPieces } from '../data/seed';

const composerCount = new Set(seedPieces.map(p => p.composer_name)).size;
const editionCount = seedPieces.reduce((sum, p) => sum + p.editions.length, 0);
const instruments = [...new Set(seedPieces.flatMap(p => p.instruments))];

const seoDescription = `Irregular Pearl is a non-profit, collaborative platform for classical music knowledge. ${seedPieces.length} pieces, ${composerCount} composers, ${editionCount}+ editions — all free and open.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Irregular Pearl',
  description: seoDescription,
  url: Astro.url.href,
  mainEntity: {
    '@type': 'Organization',
    name: 'Irregular Pearl',
    url: Astro.url.origin,
    description: seoDescription,
    nonprofitStatus: 'NonprofitType',
    foundingDate: '2026',
    knowsAbout: ['Classical Music', 'Sheet Music Editions', 'Music Repertoire', 'Music Education'],
  },
};
---
<Layout title="About" description={seoDescription} jsonLd={jsonLd}>
  <Navbar />

  <main class="max-w-2xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <h1 class="font-display text-3xl md:text-4xl italic mb-6">About Irregular Pearl</h1>

    <div class="space-y-6 text-sm md:text-base text-[#57534E] leading-relaxed">
      <p>
        Irregular Pearl is a non-profit platform that organizes classical music knowledge around the <strong class="text-ink">piece</strong> as the atomic unit. Every musical work gets a living page with structured metadata, edition comparisons, recordings, and community discussion from working musicians.
      </p>

      <p>
        The name comes from the etymology of <em>baroque</em> — from the Portuguese <em>barroco</em>, meaning an irregularly shaped pearl. Like the era that gave us Bach, Vivaldi, and Handel, we believe the most interesting things are rarely perfectly round.
      </p>

      <h2 class="font-display text-xl md:text-2xl italic text-ink pt-4">What we do</h2>

      <ul class="space-y-3 list-none pl-0">
        <li class="flex gap-3">
          <span class="text-[#B45309] font-semibold flex-shrink-0">Catalog.</span>
          <span>{seedPieces.length} pieces across {instruments.length} instrument families, from Baroque to 20th Century. Each piece has a title, composer, catalog number, era, form, difficulty, and a written description.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#B45309] font-semibold flex-shrink-0">Compare.</span>
          <span>{editionCount}+ editions with publisher, editor, year, and editorial notes. Side-by-side comparison so you can pick the right score for your level and taste.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#B45309] font-semibold flex-shrink-0">Discuss.</span>
          <span>Every piece has a threaded discussion where musicians share fingerings, tempos, interpretive choices, and practice strategies.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#B45309] font-semibold flex-shrink-0">Track.</span>
          <span>Log your practice, lessons, performances, and listening. See what the community is working on.</span>
        </li>
      </ul>

      <h2 class="font-display text-xl md:text-2xl italic text-ink pt-4">For musicians, teachers, and students</h2>

      <p>
        Whether you're a conservatory student picking your next recital piece, a teacher building a syllabus, or a returning adult player looking for the right edition of a Chopin nocturne — Irregular Pearl gives you the information that used to require asking a dozen people.
      </p>

      <h2 class="font-display text-xl md:text-2xl italic text-ink pt-4">Open and free</h2>

      <p>
        Irregular Pearl is a non-profit. All piece data, edition information, and community discussion are free to access. We link to IMSLP for public domain scores, YouTube for recordings, and Wikipedia for background.
      </p>

      <div class="border-t border-border pt-6 mt-8">
        <p class="text-xs text-muted">
          {seedPieces.length} pieces · {composerCount} composers · {editionCount}+ editions
        </p>
      </div>
    </div>
  </main>
</Layout>
