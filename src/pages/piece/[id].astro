---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import DiscussionSidebar from '../../components/DiscussionSidebar';
import WorkingOnButton from '../../components/WorkingOnButton';
import PieceTabs from '../../components/PieceTabs';
import { seedPieces } from '../../data/seed';

const { id } = Astro.params;
const piece = seedPieces.find(p => p.id === id);

if (!piece) {
  return Astro.redirect('/');
}

const breadcrumb = [piece.instruments[0] || 'Music', piece.composer_name];
const seoDescription = `${piece.title}${piece.catalog_number ? ` (${piece.catalog_number})` : ''} by ${piece.composer_name} — compare ${piece.editions.length} editions, listen to recordings, and discuss with musicians. ${piece.description.slice(0, 120)}`;

const youtubeLinks = piece.external_links.filter(l => l.type === 'youtube');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicComposition',
  name: piece.title,
  alternateName: piece.catalog_number || undefined,
  composer: {
    '@type': 'Person',
    name: piece.composer_name,
  },
  musicCompositionForm: piece.form,
  genre: piece.era,
  description: piece.description,
  instrument: piece.instruments,
  timeRequired: piece.duration_minutes ? `PT${piece.duration_minutes}M` : undefined,
  url: Astro.url.href,
  // Google-friendly: link to recordings as audio objects
  recordedAs: youtubeLinks.map(l => ({
    '@type': 'MusicRecording',
    name: l.label,
    url: l.url,
  })),
  // Speakable for Google Assistant
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.description', '.edition-name'],
  },
  isPartOf: {
    '@type': 'WebSite',
    name: 'Irregular Pearl',
    url: Astro.url.origin,
  },
  // FAQPage-style: helps Google show piece info in featured snippets
  mainEntity: {
    '@type': 'Question',
    name: `What are the best editions of ${piece.title} by ${piece.composer_name}?`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: piece.editions.map(e => `${e.publisher} (${e.editor}${e.year ? `, ${e.year}` : ''}): ${e.description}`).join(' '),
    },
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.url.origin },
    { '@type': 'ListItem', position: 2, name: piece.instruments[0] || 'Music', item: `${Astro.url.origin}/?q=${encodeURIComponent(piece.instruments[0] || '')}` },
    { '@type': 'ListItem', position: 3, name: piece.title },
  ],
};
---
<Layout
  title={piece.title}
  description={seoDescription}
  ogType="music.song"
  jsonLd={[jsonLd, breadcrumbLd]}
>
  <Navbar />

  <!-- Breadcrumb -->
  <div class="px-4 md:px-6 py-2 text-xs text-muted border-b border-border/50 bg-surface">
    <a href="/" class="hover:text-ink">Home</a>
    {breadcrumb.map((crumb) => (
      <span>
        <span class="mx-1">›</span>
        <span class="text-muted">{crumb}</span>
      </span>
    ))}
  </div>

  <!-- Main two-column layout -->
  <div class="grid grid-cols-1 md:grid-cols-[1fr_280px] lg:grid-cols-[1fr_340px] min-h-[calc(100vh-8rem)]">

    <!-- Left: Piece content -->
    <main class="px-4 md:px-8 lg:px-10 py-6 md:py-8 md:border-r border-border">

      <!-- Header -->
      <div class="mb-6">
        <h1 class="font-display text-xl md:text-2xl lg:text-[28px] leading-tight mb-1">
          {piece.title}
          {piece.catalog_number && (
            <span class="font-mono text-muted text-sm md:text-base">, {piece.catalog_number}</span>
          )}
        </h1>
        <p class="text-sm md:text-base text-muted mb-3">
          by <span class="text-ink underline decoration-border">{piece.composer_name}</span>
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap items-center gap-2 mb-4 text-xs md:text-sm text-muted">
          {piece.instruments.map((inst) => (
            <span class="bg-bg border border-border px-2 py-0.5 rounded">{inst}</span>
          ))}
          <span class="bg-bg border border-border px-2 py-0.5 rounded">{piece.era}</span>
          <span class="bg-bg border border-border px-2 py-0.5 rounded">{piece.form}</span>
          {piece.duration_minutes && <span>~{piece.duration_minutes} min</span>}
          <span class="capitalize">{piece.difficulty}</span>
        </div>

        <!-- Working On (React island) -->
        <WorkingOnButton pieceId={piece.id} client:load />
      </div>

      <!-- Tabbed content (React island) -->
      <PieceTabs piece={piece} client:load />
    </main>

    <!-- Right: Discussion sidebar (React island, always hydrated) -->
    <aside class="bg-surface px-4 md:px-5 py-6 md:py-8">
      <DiscussionSidebar pieceId={piece.id} pieceTitle={piece.title} client:load />
    </aside>
  </div>
</Layout>
