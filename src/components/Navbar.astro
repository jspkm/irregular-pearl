---
import AuthButton from './AuthButton';
---
<nav class="flex items-center justify-between px-4 md:px-6 py-3 border-b border-border bg-surface sticky top-0 z-50">
  <a href="/" class="font-display italic text-xl whitespace-nowrap text-ink no-underline">
    Irregular Pearl
  </a>

  <div class="flex-1 max-w-md mx-4 md:mx-8">
    <form action="/" method="get">
      <input
        type="search"
        name="q"
        placeholder="Search pieces, composers..."
        class="w-full px-3 py-2 border border-border rounded-lg text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent-light font-body"
      />
    </form>
  </div>

  <div class="flex items-center gap-4 text-sm text-muted">
    <a href="/" class="hidden sm:inline hover:text-ink">Browse</a>
    <AuthButton client:load />
  </div>
</nav>
