---
interface Props {
  publisher: string;
  editor: string;
  year: number | null;
  description: string;
}

const { publisher, editor, year, description } = Astro.props;
---
<div class="border border-gray-200 rounded-lg p-3 md:p-4 bg-white">
  <div class="flex justify-between items-start gap-4">
    <div class="min-w-0">
      <h3 class="font-semibold text-sm">{publisher}</h3>
      <p class="text-xs text-gray-500 mt-0.5">
        {editor}{year ? `, ${year}` : ''}
      </p>
      <p class="text-xs text-gray-500 mt-1.5 leading-relaxed">{description}</p>
    </div>
    <div class="text-right flex-shrink-0">
      <div class="text-star text-sm">★★★★☆</div>
      <div class="text-[11px] text-gray-400 mt-0.5">0 reviews</div>
    </div>
  </div>

  <!-- Rating prompt (empty state) -->
  <div class="mt-2 pt-2 border-t border-gray-100">
    <p class="text-xs text-gray-400 italic">
      Have you played from this edition? Sign in to rate it.
    </p>
  </div>
</div>
